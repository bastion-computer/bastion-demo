{
  "resources": {
    "vcpu": 2,
    "memory": 2,
    "volume": 20
  },
  "tunnels": {
    "tracker": 3000
  },
  "agents": {
    "opencode": {
      "working_directory": "/workspace/bastion-demo",
      "auth": {
        "openai": {
          "type": "api",
          "key": "${{ secret.OPENAI_API_KEY }}"
        }
      },
      "config": {
        "model": "openai/gpt-5.5",
        "permission": "allow"
      }
    }
  },
  "actions": {
    "init": [
      {
        "use": "setup_bun",
        "with": {
          "version": "bun-v1.3.13"
        }
      },
      {
        "run": "apt-get update && apt-get install -y ca-certificates git"
      },
      {
        "run": "git clone https://github.com/bastion-computer/bastion-demo.git bastion-demo",
        "working_directory": "/workspace"
      },
      {
        "run": "bun install --frozen-lockfile && bun test",
        "working_directory": "/workspace/bastion-demo"
      },
      {
        "use": "set_default_ssh_directory",
        "with": {
          "path": "/workspace/bastion-demo"
        }
      }
    ],
    "start": [
      {
        "run": "git pull --ff-only",
        "working_directory": "/workspace/bastion-demo"
      },
      {
        "run": "nohup bun run dev > /tmp/bastion-demo-dev.log 2>&1 &",
        "working_directory": "/workspace/bastion-demo"
      }
    ]
  }
}
